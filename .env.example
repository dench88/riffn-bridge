# @riffn/bridge configuration. `riffn-bridge init` writes this for you; edit only if you need to.
# The essentials are RIFFIN_BRIDGE_TOKEN, RIFFIN_BRIDGE_CWD, and RIFFIN_BRIDGE_AGENT.

# Bearer token the helper requires. The app receives this via the pairing QR; treat it like a
# password. Rotate any time with `riffn-bridge rotate`.
RIFFIN_BRIDGE_TOKEN=

# Working directory the agent runs in (e.g. the repo you want Claude Code to reason about).
RIFFIN_BRIDGE_CWD=

# Which CLI agent to drive (Mode A): claude | codex | custom. For claude/codex, v1 is
# READ/PLAN-ONLY — the agent is never granted write/execute permission. (Write/exec + voice
# approval is a separate, gated project.)
RIFFIN_BRIDGE_AGENT=claude

# Edit mode (edit_mode_plan.md): disabled | limited | ungated. Default disabled.
#   disabled — chat and tasks are read/plan-only. Codex runs --sandbox read-only with an
#              isolated config (your ~/.codex/config.toml — MCP servers, hooks, web search —
#              is never loaded under the bridge). NOTE: Codex's sandbox contains what shell
#              commands can DO, not whether they run — read-only commands still execute.
#   limited  — chat stays read-only; a voice-confirmed edit TASK ("execute the plan" +
#              confirm) may edit files (Claude only; snapshot-first, no commands, no git).
#   ungated  — 🚨 the confirmation gate is OFF: ANY turn may edit files (permitted every turn,
#              not performed every turn). Claude: edits stay contained (no commands/git/MCP) and
#              every write-capable turn snapshots first (refs/riffn/ring-*, last 20 kept).
#              Codex: SANDBOXED SHELL + WORKSPACE EDITS (--sandbox workspace-write) — model-run
#              commands execute, contained to the workdir; no automatic snapshots. Only set this
#              if you accept that anyone with your phone or pairing token can modify this repo
#              at will. ("full-access" / "always-edit" are deprecated spellings.)
# RIFFIN_BRIDGE_EDIT_MODE=disabled

# Legacy alias for the above (honored only when EDIT_MODE is unset AND the agent is claude):
# 1 means "limited".
RIFFIN_BRIDGE_ALLOW_EDIT_JOBS=0

# Custom CLI agent (RIFFIN_BRIDGE_AGENT=custom) — any coding-agent CLI (aider, opencode, etc.).
# BIN is the binary; ARGS is a whitespace-split template where {prompt} becomes one argument
# (no {prompt} → the prompt is appended last). Invoked as an argument array, never a shell.
# ⚠️ riffn-bridge CANNOT enforce read-only on an arbitrary CLI — configure the tool itself;
# /health reports caps=operator-defined. Custom agents are stateless (no session continuity).
# RIFFIN_BRIDGE_AGENT_BIN=aider
# RIFFIN_BRIDGE_AGENT_ARGS=--message {prompt} --no-auto-commits

# Port to listen on.
RIFFIN_BRIDGE_PORT=8765

# Bind address. Default: auto-detected Tailscale (100.64.0.0/10) address.
#   - Set to 127.0.0.1 if you front the helper with `tailscale serve` for HTTPS.
#   - Set to a specific tailnet IP to override auto-detection.
# RIFFIN_BRIDGE_HOST=

# Paths to the agent binaries if not on PATH.
# RIFFIN_BRIDGE_CLAUDE_BIN=claude
# RIFFIN_BRIDGE_CODEX_BIN=codex

# Model id reported to Riffn (cosmetic).
# RIFFIN_BRIDGE_MODEL=riffn-bridge

# Per-request timeout (ms) before the agent is killed.
# RIFFIN_BRIDGE_TIMEOUT_MS=120000

# Diagnostic logging. OFF by default (logs redact token/prompts/code/cwd/args/URLs). Set to 1 ONLY
# for local debugging — verbose logs MAY capture sensitive data.
# RIFFIN_BRIDGE_VERBOSE=1

# Escape hatch: bind 0.0.0.0 (PUBLIC) when no Tailscale address is found. Not recommended.
# RIFFIN_BRIDGE_ALLOW_PUBLIC=1

# ---- HTTP LLM proxy (Mode B — a later phase) --------------------------------
# Proxy chat to your existing local LLM server instead of driving a CLI agent.
# RIFFIN_BRIDGE_LLM_URL=http://127.0.0.1:11434/v1/chat/completions
# RIFFIN_BRIDGE_LLM_KEY=
# RIFFIN_BRIDGE_LLM_MODEL=

# ---- Local TTS (optional; Mode B) -------------------------------------------
# HTTP mode: an OpenAI-compatible POST /v1/audio/speech endpoint to forward text to.
# RIFFIN_BRIDGE_TTS_URL=http://127.0.0.1:8080/v1/audio/speech
# RIFFIN_BRIDGE_TTS_KEY=
# RIFFIN_BRIDGE_TTS_MODEL=tts-1
# RIFFIN_BRIDGE_TTS_VOICE=default
# RIFFIN_BRIDGE_TTS_FORMAT=mp3   # mp3 | aac | wav | opus | flac
# CLI mode (fallback): a command that reads text on STDIN and writes audio bytes to STDOUT.
# RIFFIN_BRIDGE_TTS_CMD=
